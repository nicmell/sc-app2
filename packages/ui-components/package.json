{
  "name": "@sc-app/ui-components",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Framework-agnostic CSS foundation for sc-app: tokens, base element styles, and a small set of semantic-class primitives. Shared between the React host and future runtime HTML plugins.",
  "exports": {
    ".": "./src/foundations/index.scss",
    "./reset": "./src/foundations/reset.scss",
    "./tokens": "./src/foundations/tokens/index.scss",
    "./themes/dark": "./src/foundations/tokens/themes/dark.scss",
    "./themes/light": "./src/foundations/tokens/themes/light.scss",
    "./lit": "./src/components/index.ts",
    "./react": "./src/components/react.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "demo": "vite example",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lit/context": "^1.1.6",
    "@lit/react": "^1.0.6",
    "classnames": "^2.5.1"
  },
  "peerDependencies": {
    "lit": "^3.3.3",
    "react": "^19",
    "react-dom": "^19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@phosphor-icons/web": "^2.1.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "happy-dom": "^20.10.2",
    "lit": "^3.3.3",
    "react": "^19",
    "react-dom": "^19",
    "sass": "^1.101.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
