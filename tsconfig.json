{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* `@/` → `src/` (mirrors the old sc-app convention; vite.config.ts has
       the matching resolve.alias) */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src"],
  /* Co-located tests run through Vitest's own glob, not the build. Exclude
     them from `tsc` (yarn build) — they use Vite-only imports (`?raw`,
     `import.meta.glob`) that have no ambient types here. */
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/test-setup.ts"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
