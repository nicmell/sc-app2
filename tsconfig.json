{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    /* Resolve the `development` export condition so `@sc-app/*` typecheck against
       package SOURCE (.ts) — no prior package build needed. Mirrors Vite/vitest
       dev resolution; production `vite build` uses the `default` (dist) condition. */
    "customConditions": ["development"],
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* `@/` → `src/` (mirrors the old sc-app convention; vite.config.ts has
       the matching resolve.alias) */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  /* The whole src tree — incl. the co-located __tests__ and the shared test
     scaffolding (src/lib/utils/test) — is type-checked. Vite-only imports
     (`?raw`, `import.meta.glob`) resolve through vite/client (src/vite-env.d.ts);
     vitest's types come from its package. */
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
