{
  "name": "@sc-app/synthdef-compiler",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Pure TypeScript SuperCollider SynthDef (SCgf v2) compiler.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./builders": {
      "development": "./src/builders/index.ts",
      "types": "./dist/builders/index.d.ts",
      "default": "./dist/builders/index.js"
    },
    "./registry": {
      "development": "./src/registry.ts",
      "types": "./dist/registry.d.ts",
      "default": "./dist/registry.js"
    },
    "./sugar": {
      "development": "./src/sugar/index.ts",
      "types": "./dist/sugar/index.d.ts",
      "default": "./dist/sugar/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "parity": "tsx examples/node/sclang_parity.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "~5.6.2",
    "vitest": "^2.1.9"
  }
}
