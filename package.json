{
  "name": "sc-app2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "packages/ui-components/example"
  ],
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently --names vite,server --prefix-colors auto --kill-others-on-fail \"yarn dev\" \"yarn serve\"",
    "build": "tsc && vite build",
    "lint": "eslint src packages",
    "format": "prettier --write src packages",
    "format:check": "prettier --check src packages",
    "typecheck": "tsc --noEmit && yarn workspace @sc-app/ui-components typecheck",
    "test": "vitest run && yarn workspace @sc-app/synthdef-compiler test && yarn workspace @sc-app/ui-components test",
    "test:all": "yarn test && cargo test --manifest-path src-tauri/Cargo.toml",
    "clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "fmt:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "fmt:rust:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --check",
    "preview": "vite preview",
    "tauri": "tauri",
    "serve": "cargo run --manifest-path src-tauri/Cargo.toml -- serve --config ./config.json --log-dir ./logs",
    "deps": "./scripts/setup-deps.sh",
    "osc": "./scripts/start-osc.sh",
    "strudeldirt": "./scripts/start-strudeldirt.sh"
  },
  "dependencies": {
    "@lit/react": "^1.0.6",
    "@sc-app/server-commands": "workspace:*",
    "@sc-app/synthdef-compiler": "workspace:*",
    "@sc-app/ui-components": "workspace:*",
    "@strudel/codemirror": "^1.3.0",
    "@strudel/core": "^1.2.6",
    "@strudel/mini": "^1.2.6",
    "@strudel/tonal": "^1.2.6",
    "@strudel/transpiler": "^1.2.6",
    "classnames": "^2.5.1",
    "lit": "^3.3.3",
    "osc-js": "^2.4.1",
    "react": "^19",
    "react-dom": "^19",
    "react-grid-layout": "^2.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-grid-layout": "^2.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lit": "^2.3.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.2",
    "prettier": "^3.8.4",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.56.0",
    "vite": "^6.0.3",
    "vite-plugin-lit-css": "^3.0.0",
    "vitest": "^4.1.8"
  },
  "packageManager": "yarn@4.14.1"
}
