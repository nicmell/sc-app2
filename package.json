{
  "name": "sc-app2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently --names vite,server --prefix-colors auto --kill-others-on-fail \"yarn dev\" \"yarn serve\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "serve": "cargo run --manifest-path src-tauri/Cargo.toml -- serve --config ./config.json --log-dir ./logs",
    "deps": "./scripts/setup-deps.sh",
    "osc": "./scripts/start-osc.sh",
    "strudeldirt": "./scripts/start-strudeldirt.sh"
  },
  "dependencies": {
    "@sc-app/server-commands": "workspace:*",
    "@sc-app/ui-foundation": "workspace:*",
    "@strudel/codemirror": "^1.3.0",
    "@strudel/core": "^1.2.6",
    "@strudel/mini": "^1.2.6",
    "@strudel/tonal": "^1.2.6",
    "@strudel/transpiler": "^1.2.6",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "lit": "^3.3.3",
    "osc-js": "^2.4.1",
    "react": "^19",
    "react-dom": "^19",
    "react-grid-layout": "^2.2.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-grid-layout": "^2.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  },
  "packageManager": "yarn@4.14.1"
}
