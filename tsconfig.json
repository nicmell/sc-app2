{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* `@/` → `src/` (mirrors the old sc-app convention; vite.config.ts has
       the matching resolve.alias) */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src"],
  /* Co-located tests run through Vitest's own glob, not the build. Exclude
     them — and the shared test scaffolding (src/lib/utils/test) — from `tsc`
     (yarn build): they pull in `vitest` and Vite-only imports (`?raw`,
     `import.meta.glob`) that don't belong in the app build. */
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/lib/utils/test/**"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
