{
  "name": "@sc-app/synthdef-compiler",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Pure TypeScript SuperCollider SynthDef (SCgf v2) compiler.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./builders": "./src/builders/index.ts",
    "./registry": "./src/registry.ts",
    "./sugar": "./src/sugar/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "parity": "tsx examples/node/sclang_parity.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "~5.6.2",
    "vitest": "^2.1.9"
  }
}
