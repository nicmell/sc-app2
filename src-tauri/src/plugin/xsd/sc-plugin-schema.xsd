<xs:schema
    xmlns:xs="http://www.w3.org/2001/XMLSchema"
    targetNamespace="http://www.w3.org/1999/xhtml"
    xmlns="http://www.w3.org/1999/xhtml"
    elementFormDefault="qualified">

  <!-- sc-plugin schema: a basic XHTML wrapper containing simple layout HTML
       plus the sc-* custom elements. Grows with each element migration step;
       keep in sync with src/constants/sc-elements.ts and the runtime
       validation in src/lib/html/handlers.ts. -->

  <xs:attributeGroup name="commonAttrs">
    <xs:attribute name="id" type="xs:string" use="optional"/>
    <xs:attribute name="class" type="xs:string" use="optional"/>
    <xs:attribute name="title" type="xs:string" use="optional"/>
    <xs:attribute name="style" type="xs:string" use="optional"/>
  </xs:attributeGroup>

  <!-- ==================== Element declarations ==================== -->

  <!-- Layout HTML -->
  <xs:element name="div" type="blockType"/>
  <xs:element name="p" type="inlineType"/>
  <xs:element name="label" type="blockType"/>
  <xs:element name="span" type="inlineType"/>
  <xs:element name="strong" type="inlineType"/>
  <xs:element name="em" type="inlineType"/>
  <xs:element name="h1" type="inlineType"/>
  <xs:element name="h2" type="inlineType"/>
  <xs:element name="h3" type="inlineType"/>
  <xs:element name="h4" type="inlineType"/>
  <xs:element name="h5" type="inlineType"/>
  <xs:element name="h6" type="inlineType"/>
  <xs:element name="hr"/>
  <xs:element name="br"/>

  <!-- sc-* elements -->
  <xs:element name="sc-console" type="scLeafType"/>
  <xs:element name="sc-scope" type="scLeafType"/>
  <xs:element name="sc-strudel" type="scLeafType"/>
  <xs:element name="sc-synthdef" type="scSynthDefType"/>
  <xs:element name="sc-ugen" type="scUGenType"/>
  <xs:element name="sc-control" type="scControlType"/>
  <xs:element name="sc-synth" type="scSynthType"/>
  <xs:element name="sc-range" type="scRangeType"/>

  <!-- ==================== Content model groups ==================== -->

  <xs:group name="blockContent">
    <xs:choice>
      <xs:element ref="div"/>
      <xs:element ref="p"/>
      <xs:element ref="label"/>
      <xs:element ref="span"/>
      <xs:element ref="strong"/>
      <xs:element ref="em"/>
      <xs:element ref="h1"/>
      <xs:element ref="h2"/>
      <xs:element ref="h3"/>
      <xs:element ref="h4"/>
      <xs:element ref="h5"/>
      <xs:element ref="h6"/>
      <xs:element ref="hr"/>
      <xs:element ref="br"/>
      <xs:element ref="sc-console"/>
      <xs:element ref="sc-scope"/>
      <xs:element ref="sc-strudel"/>
      <xs:element ref="sc-synthdef"/>
      <xs:element ref="sc-synth"/>
      <xs:element ref="sc-range"/>
    </xs:choice>
  </xs:group>

  <xs:group name="inlineContent">
    <xs:choice>
      <xs:element ref="span"/>
      <xs:element ref="strong"/>
      <xs:element ref="em"/>
      <xs:element ref="br"/>
    </xs:choice>
  </xs:group>

  <!-- ==================== Root ==================== -->

  <xs:element name="title" type="xs:string"/>
  <xs:element name="head">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="title"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="body" type="blockType"/>

  <xs:element name="html">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="head"/>
        <xs:element ref="body"/>
      </xs:sequence>
      <xs:attribute name="id" type="xs:string" use="optional"/>
    </xs:complexType>
  </xs:element>

  <!-- ==================== Complex types ==================== -->

  <xs:complexType name="blockType" mixed="true">
    <xs:choice minOccurs="0" maxOccurs="unbounded">
      <xs:group ref="blockContent"/>
    </xs:choice>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <xs:complexType name="inlineType" mixed="true">
    <xs:choice minOccurs="0" maxOccurs="unbounded">
      <xs:group ref="inlineContent"/>
    </xs:choice>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- Leaf custom elements: no custom attrs yet. -->
  <xs:complexType name="scLeafType">
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-synthdef: a synth graph — sc-control params + sc-ugen nodes. -->
  <xs:complexType name="scSynthDefType">
    <xs:choice minOccurs="0" maxOccurs="unbounded">
      <xs:element ref="sc-control"/>
      <xs:element ref="sc-ugen"/>
    </xs:choice>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-ugen: one UGen node; sc-control children are its inputs. -->
  <xs:complexType name="scUGenType">
    <xs:choice minOccurs="0" maxOccurs="unbounded">
      <xs:element ref="sc-control"/>
    </xs:choice>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="type" type="xs:string" use="required"/>
    <xs:attribute name="rate" type="xs:string"/>
    <xs:attribute name="op" type="xs:string"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-control: a literal value or a bind reference. -->
  <xs:complexType name="scControlType">
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="value" type="xs:decimal"/>
    <xs:attribute name="bind" type="xs:string"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-synth: a synthdef instance; sc-control children are its params. -->
  <xs:complexType name="scSynthType">
    <xs:choice minOccurs="0" maxOccurs="unbounded">
      <xs:element ref="sc-control"/>
    </xs:choice>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="bind" type="xs:string"/>
    <xs:attribute name="run" type="xs:boolean"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

  <!-- sc-range: a range input bound to a control. -->
  <xs:complexType name="scRangeType">
    <xs:attribute name="bind" type="xs:string"/>
    <xs:attribute name="min" type="xs:decimal"/>
    <xs:attribute name="max" type="xs:decimal"/>
    <xs:attribute name="step" type="xs:decimal"/>
    <xs:attribute name="value" type="xs:decimal"/>
    <xs:attributeGroup ref="commonAttrs"/>
  </xs:complexType>

</xs:schema>
